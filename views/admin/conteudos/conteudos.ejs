<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conteúdos Relacionados • Ludus</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <%- include('../../partials/sidebar') %>
    <main class="main-content">
      <h1>Conteúdos Relacionados</h1>

      <section>
        <h2>Criar novo</h2>
    <form id="createForm" method="post" action="/api/conteudos" enctype="multipart/form-data">
      <div>
        <label>Título</label>
        <input name="titulo" required />
      </div>
      <div>
        <label>Descrição</label>
        <textarea name="descricao" required></textarea>
      </div>
      <div>
        <label>Tipo</label>
        <select name="tipo">
          <option value="">-- selecione --</option>
          <option value="artigo">Artigo</option>
          <option value="evento">Evento</option>
        </select>
      </div>
      <div>
        <label>Link Externo (opcional)</label>
        <input name="link_externo" />
      </div>
      <div>
        <label>Tag (opcional)</label>
        <input name="tag" list="tagSuggestions" />
        <datalist id="tagSuggestions"></datalist>
      </div>
      <div>
        <label>Jogos vinculados</label>
        <p class="helper-text">Selecione um ou mais jogos. Sem seleção, o conteúdo continua sendo salvo, mas não aparece em nenhuma página de jogo.</p>
        <div id="createGamePicker" class="game-picker"></div>
        <input type="hidden" name="jogos" id="createJogosInput" />
      </div>
      <div>
        <label>Arquivo PDF (opcional)</label>
        <input type="file" name="arquivo_pdf" accept="application/pdf" />
      </div>
      <div>
        <button type="submit">Criar</button>
      </div>
    </form>
      </section>

      <section>
        <h2>Lista</h2>
        <div id="list"></div>
      </section>
    </main>
  </div>

  <script>
async function loadList(){
  const res = await fetch('/api/conteudos', { credentials: 'same-origin' });
  const items = await res.json();
  const root = document.getElementById('list');
  const tagSuggestions = document.getElementById('tagSuggestions');
  root.innerHTML = '';
  if(!items.length) { root.innerHTML = '<p>Nenhum conteúdo cadastrado.</p>'; return; }
  const uniqueTags = Array.from(new Set(items.map(item => (item.tag || '').trim()).filter(Boolean))).sort((a, b) => a.localeCompare(b, 'pt-BR'));
  tagSuggestions.innerHTML = uniqueTags.map(tag => `<option value="${tag.replace(/"/g, '&quot;')}"></option>`).join('');
  const table = document.createElement('table');
  table.border = 1;
  const thead = document.createElement('thead');
  thead.innerHTML = '<tr><th>Título</th><th>Tipo</th><th>Link</th><th>Arquivo</th><th>Jogos</th><th>Ações</th></tr>';
  table.appendChild(thead);
  const tbody = document.createElement('tbody');
  for(const it of items){
    const tr = document.createElement('tr');
    const hasPdf = Boolean(it.pdf_url || it.pdf_id || it.pdf);
    const externalLinkHtml = it.link_externo ? `<a href="${it.link_externo}" target="_blank" rel="noopener noreferrer">Abrir URL</a>` : '';
    const pdfLinkHtml = hasPdf ? `<a href="/conteudo/public/pdf/${it._id}" target="_blank" rel="noopener noreferrer">Abrir arquivo</a>` : '';
    tr.innerHTML = `<td>${it.titulo}</td><td>${it.tipo||''}</td><td>${externalLinkHtml}</td><td>${pdfLinkHtml}</td><td>${(it.jogos||[]).join(', ')}</td><td></td>`;
    const actions = tr.querySelector('td:last-child');
    const editBtn = document.createElement('button'); editBtn.textContent='Editar';
    editBtn.addEventListener('click', ()=> openEdit(it));
    const delBtn = document.createElement('button'); delBtn.textContent='Remover';
    delBtn.addEventListener('click', ()=> removeItem(it._id));
    actions.appendChild(editBtn); actions.appendChild(delBtn);
    tbody.appendChild(tr);
  }
  table.appendChild(tbody);
  root.appendChild(table);
}

  async function loadGamePickers(selectedIds = [], targetId = 'createGamePicker') {
    const target = document.getElementById(targetId);
    if (!target) return;

    const res = await fetch('/api/jogos', { credentials: 'same-origin' });
    const jogos = await res.json();
    const selectedSet = new Set((selectedIds || []).map(String));

    target.innerHTML = jogos.map((jogo) => {
      const id = String(jogo._id);
      const checked = selectedSet.has(id) ? 'checked' : '';
      const nome = (jogo.nome || id).replace(/"/g, '&quot;');
      return `
        <label class="game-picker__item">
          <input type="checkbox" value="${id}" ${checked} data-game-checkbox />
          <span>${nome}</span>
        </label>
      `;
    }).join('');

    return jogos;
  }

  function syncSelectedGames(container, hiddenInput) {
    if (!container || !hiddenInput) return;
    const selected = Array.from(container.querySelectorAll('[data-game-checkbox]:checked')).map((input) => input.value);
    hiddenInput.value = selected.join(',');
  }

  function wireGamePicker(containerId, hiddenInputId) {
    const container = document.getElementById(containerId);
    const hiddenInput = document.getElementById(hiddenInputId);
    if (!container || !hiddenInput) return;
    container.addEventListener('change', () => syncSelectedGames(container, hiddenInput));
    syncSelectedGames(container, hiddenInput);
  }

function openEdit(item){
  const overlay = document.createElement('div');
  overlay.style.position='fixed'; overlay.style.left=0; overlay.style.top=0; overlay.style.right=0; overlay.style.bottom=0; overlay.style.background='rgba(0,0,0,0.4)';
  const box = document.createElement('div'); box.style.background='#fff'; box.style.padding='1rem'; box.style.margin='2rem';
  box.innerHTML = `
    <h3>Editar: ${item.titulo}</h3>
    <form id="editForm">
      <div><label>Título</label><input name="titulo" value="${item.titulo||''}" required /></div>
      <div><label>Descrição</label><textarea name="descricao" required>${item.descricao||''}</textarea></div>
      <div><label>Tipo</label><select name="tipo"><option value="">--</option><option value="artigo">Artigo</option><option value="evento">Evento</option></select></div>
      <div><label>Link Externo</label><input name="link_externo" value="${item.link_externo||''}" /></div>
      <div><label>Tag</label><input name="tag" value="${item.tag||''}" /></div>
      <div>
        <label>Jogos vinculados</label>
        <p class="helper-text">Marque os jogos que devem exibir este conteúdo.</p>
        <div id="editGamePicker" class="game-picker"></div>
        <input type="hidden" name="jogos" id="editJogosInput" />
      </div>
      <div><button type="submit">Salvar</button> <button type="button" id="cancelBtn">Cancelar</button></div>
    </form>
  `;
  overlay.appendChild(box);
  document.body.appendChild(overlay);
  const form = box.querySelector('#editForm');
  const select = form.querySelector('select[name="tipo"]');
  if(item.tipo && item.tipo.toLowerCase()==='evento') select.value='evento';
  if(item.tipo && item.tipo.toLowerCase()==='artigo') select.value='artigo';
  if (item.pdf_url || item.pdf_id || item.pdf) {
    const pdfLink = document.createElement('p');
    pdfLink.innerHTML = `<a href="/conteudo/public/pdf/${item._id}" target="_blank" rel="noopener noreferrer">Abrir arquivo enviado</a>`;
    box.insertBefore(pdfLink, form);
  }
  loadGamePickers((item.jogos || []).map(String), 'editGamePicker').then(() => {
    wireGamePicker('editGamePicker', 'editJogosInput');
  });
  form.addEventListener('submit', async (e)=>{
    e.preventDefault();
    const data = new FormData(form);
    // build plain object to send as JSON (no file upload via edit)
    const payload = {};
    for(const [k,v] of data.entries()) payload[k]=v;
    // if link_externo is empty string, send empty string so backend clears it
    const res = await fetch('/api/conteudos/'+item._id, { method:'PUT', headers:{'Content-Type':'application/json'}, credentials:'same-origin', body: JSON.stringify(payload) });
    if(res.ok){ alert('Atualizado'); loadList(); document.body.removeChild(overlay); } else { alert('Erro ao atualizar'); }
  });
  box.querySelector('#cancelBtn').addEventListener('click', ()=> document.body.removeChild(overlay));
}

async function removeItem(id){
  if(!confirm('Remover conteúdo?')) return;
  const res = await fetch('/api/conteudos/'+id, { method:'DELETE', credentials:'same-origin' });
  if(res.ok) loadList(); else alert('Erro ao remover');
}

window.addEventListener('load', ()=>{ loadList(); });
loadGamePickers([], 'createGamePicker').then(() => {
  wireGamePicker('createGamePicker', 'createJogosInput');
});
</script>

<%- include('../../rodape.ejs') %>